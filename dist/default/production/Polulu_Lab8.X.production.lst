 18114                           ;Config register CONFIG1L @ 0x300000
 18115                           ;	External Oscillator Selection
 18116                           ;	FEXTOSC = OFF, Oscillator not enabled
 18117                           ;	Reset Oscillator Selection
 18118                           ;	RSTOSC = HFINTOSC_1MHZ, HFINTOSC with HFFRQ = 4 MHz and CDIV = 4:1
 18119   300000                     	org	3145728
 18120   300000  EC                 	db	236
 18121                           
 18122                           ;Config register CONFIG1H @ 0x300001
 18123                           ;	Clock out Enable bit
 18124                           ;	CLKOUTEN = ON, CLKOUT function is enabled
 18125                           ;	PRLOCKED One-Way Set Enable bit
 18126                           ;	PR1WAY = ON, PRLOCK bit can be cleared and set only once
 18127                           ;	Clock Switch Enable bit
 18128                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 18129                           ;	Fail-Safe Clock Monitor Enable bit
 18130                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 18131   300001                     	org	3145729
 18132   300001  FE                 	db	254
 18133                           
 18134                           ;Config register CONFIG2L @ 0x300002
 18135                           ;	MCLR Enable bit
 18136                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 18137                           ;	Power-up timer selection bits
 18138                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 18139                           ;	Multi-vector enable bit
 18140                           ;	MVECEN = OFF, Interrupt contoller does not use vector table to prioritze interrupts
 18141                           ;	IVTLOCK bit One-way set enable bit
 18142                           ;	IVT1WAY = ON, IVTLOCK bit can be cleared and set only once
 18143                           ;	Low Power BOR Enable bit
 18144                           ;	LPBOREN = OFF, ULPBOR disabled
 18145                           ;	Brown-out Reset Enable bits
 18146                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 18147   300002                     	org	3145730
 18148   300002  F7                 	db	247
 18149                           
 18150                           ;Config register CONFIG2H @ 0x300003
 18151                           ;	Brown-out Reset Voltage Selection bits
 18152                           ;	BORV = VBOR_2P45, Brown-out Reset Voltage (VBOR) set to 2.45V
 18153                           ;	ZCD Disable bit
